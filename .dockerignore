# Build context excludes for the server image.
# Reduces the build context size sent to the buildkit daemon.

# Build outputs
**/target/
**/.gradle/
**/build/

# Node / UI artefacts (rebuilt inside the image)
**/node_modules/
**/.next/
**/.vite/
**/.turbo/
ui/dist/

# Python / virtualenvs
**/venv/
**/.venv/
**/__pycache__/
**/*.pyc
**/*.egg-info/
**/.pytest_cache/

# IDE / VCS
.git/
.idea/
.vscode/
**/*.iml

# Misc
**/.DS_Store
**/*.log

# Site / docs build outputs (not needed for the server image)
site/build/
site/.docusaurus/
